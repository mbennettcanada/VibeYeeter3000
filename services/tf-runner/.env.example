# Can point at the same Postgres instance as apps/api for now.
TF_RUNNER_DATABASE_URL=postgres://postgres:dev@localhost:5432/vibeyeeter

# Name of the OpenTofu binary on PATH. Install from https://opentofu.org if
# it's missing locally — the service logs a warning at startup rather than
# crashing when it can't find it, but /plan, /apply, and /destroy will fail.
TOFU_BIN=tofu

# Optional
LOG_LEVEL=info
PORT=4001
