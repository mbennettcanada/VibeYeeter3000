# Required
DATABASE_URL=postgres://postgres:dev@localhost:5432/vibeyeeter
JWT_SECRET=local-dev-secret

# GitHub App integration (vibeyeeter-bot) — optional locally. Without these,
# webhook and repo-op routes log a warning at startup and no-op instead of
# crashing. GITHUB_APP_PRIVATE_KEY must be the base64 encoding of the .pem
# file downloaded from the GitHub App settings page, e.g.:
#   base64 -i vibeyeeter-bot.private-key.pem
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=
GITHUB_WEBHOOK_SECRET=

# GitHub org that app repos are provisioned into. No default — must be set
# explicitly (a placeholder default would silently provision real repos into
# the wrong org).
GITHUB_ORG=your-org

# GitHub org used for container image pushes (ghcr.io/<GHCR_ORG>/<image>).
# Defaults to GITHUB_ORG; only set this if images are pushed to a different
# org/user than the one repos are provisioned into.
GHCR_ORG=

# Base domain used for per-app subdomains, e.g. internal.yourcompany.com.
PLATFORM_DOMAIN=internal.yourcompany.com

# The platform's own public URL. Templated into generated app deploy
# workflows as the deployment webhook target.
PLATFORM_URL=https://vibeyeeter.internal.yourcompany.com

# Cloudflare Access — optional locally. Set DEV_AUTH_BYPASS=true instead to
# skip SSO entirely during local development. CF_ACCESS_TEAM_DOMAIN is your
# Zero Trust team domain (e.g. yourteam.cloudflareaccess.com);
# CF_ACCESS_AUD is the Application Audience (AUD) tag from the CF Access
# application configured for this platform.
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=
SESSION_SECRET=

# Cloudflare API — used to create/delete DNS records for app hostnames
# (services/cloudflare.ts). CF_API_TOKEN needs DNS edit permission on the
# zone; CF_ZONE_ID is the zone id for PLATFORM_DOMAIN. Optional locally —
# domains are tracked in the database but DNS records are skipped if unset.
CF_API_TOKEN=
CF_ZONE_ID=

# 32-byte hex key used to encrypt sensitive platform_config values (e.g.
# CF_API_TOKEN set via /settings/config) at rest. Generate with:
#   openssl rand -hex 32
# Optional locally — if unset, those values are stored in plaintext instead.
CONFIG_ENCRYPTION_KEY=

AWS_REGION=us-east-1
TF_RUNNER_URL=http://localhost:4001
WEB_APP_URL=http://localhost:3000

# Local development only — bypasses Cloudflare Access auth with a fake admin
# user. Never set this in staging/production.
DEV_AUTH_BYPASS=true

# Optional
LOG_LEVEL=info
PORT=3002
