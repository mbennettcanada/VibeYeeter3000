# Required
DATABASE_URL=postgres://postgres:dev@localhost:5432/vibeyeeter
JWT_SECRET=local-dev-secret

# GitHub App integration (vibeyeeter-bot) — optional locally. Without these,
# webhook and repo-op routes log a warning at startup and no-op instead of
# crashing. GITHUB_APP_PRIVATE_KEY must be the base64 encoding of the .pem
# file downloaded from the GitHub App settings page, e.g.:
#   base64 -i vibeyeeter-bot.private-key.pem
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=
GITHUB_WEBHOOK_SECRET=

# GitHub org that app repos are provisioned into. No default — must be set
# explicitly (a placeholder default would silently provision real repos into
# the wrong org).
GITHUB_ORG=your-org

# GitHub org used for container image pushes (ghcr.io/<GHCR_ORG>/<image>).
# Defaults to GITHUB_ORG; only set this if images are pushed to a different
# org/user than the one repos are provisioned into.
GHCR_ORG=

# Base domain used for per-app subdomains, e.g. internal.yourcompany.com.
PLATFORM_DOMAIN=internal.yourcompany.com

# The platform's own public URL. Used as the default SAML entity/callback
# base and templated into generated app deploy workflows as the deployment
# webhook target.
PLATFORM_URL=https://vibeyeeter.internal.yourcompany.com

# JumpCloud SAML — optional locally. Set DEV_AUTH_BYPASS=true instead to skip
# SSO entirely during local development. These are not derived from
# PLATFORM_URL automatically (dotenv doesn't expand variables) — set them to
# match it explicitly.
SAML_ENTITY_ID=https://vibeyeeter.internal.yourcompany.com/saml/metadata
SAML_IDP_SSO_URL=
SAML_IDP_CERT=
SAML_CALLBACK_URL=https://vibeyeeter.internal.yourcompany.com/saml/callback
SAML_GROUPS_ATTRIBUTE=memberOf
SESSION_SECRET=

AWS_REGION=us-east-1
TF_RUNNER_URL=http://localhost:4001
WEB_APP_URL=http://localhost:3000

# Local development only — bypasses SAML auth with a fake admin user.
# Never set this in staging/production.
DEV_AUTH_BYPASS=true

# Optional
LOG_LEVEL=info
PORT=3002
