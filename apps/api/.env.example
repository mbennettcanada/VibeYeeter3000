# Required
DATABASE_URL=postgres://postgres:dev@localhost:5432/vibeyeeter
JWT_SECRET=local-dev-secret

# GitHub App integration — optional locally. Without these, webhook and
# repo-op routes log a warning at startup and no-op instead of crashing.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# JumpCloud SAML — optional locally. Set DEV_AUTH_BYPASS=true instead to skip
# SSO entirely during local development.
JUMPCLOUD_SAML_CERT=
SAML_SP_ENTITY_ID=https://vibeyeeter.internal.co/saml/metadata
SAML_CALLBACK_URL=https://vibeyeeter.internal.co/saml/callback

AWS_REGION=us-east-1
TF_RUNNER_URL=http://localhost:4001

# Local development only — bypasses SAML auth with a fake admin user.
# Never set this in staging/production.
DEV_AUTH_BYPASS=true

# Optional
LOG_LEVEL=info
PORT=3002
