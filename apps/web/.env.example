# Base URL of the platform API (apps/api). Used by src/lib/api.ts.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3002

# GitHub org used to suggest a default repo URL on the "register app" form.
# Purely cosmetic — the API does its own validation of whatever repo URL is
# submitted. Should match the API's GITHUB_ORG.
NEXT_PUBLIC_GITHUB_ORG=your-org

# Cloudflare Access — used to build the login redirect URL when a request is
# unauthenticated. Should match the API's CF_ACCESS_TEAM_DOMAIN / CF_ACCESS_AUD.
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=
